---
import WaIcon from './WaIcon.astro'
const { link } = Astro.props
const heroImg =
  'https://images.unsplash.com/photo-1534447677768-be436bb09401?auto=format&fit=crop&w=1600&q=90'
---

<section class="hero">
  <div class="hero-img" style={`background-image:url('${heroImg}')`}></div>
  <div class="hero-overlay"></div>

  <!-- Floating runes -->
  <span class="sigil s-tl">✦</span>
  <span class="sigil s-tr">✦</span>
  <span class="sigil s-bl">◈</span>
  <span class="sigil s-br">◈</span>

  <div class="hero-content">
    <div class="eyebrow">
      <span>𓂀</span>
      <span>Guía Espiritual · Tradición Ancestral · 35 Años de Experiencia</span>
      <span>𓂀</span>
    </div>

    <h1>
      <span class="h1-name">Benjamin santos</span>
      <em class="h1-gold">Maestro Espiritual</em>
      <span class="h1-sub">Amarres de Amor · Rituales · Orientación</span>
    </h1>

    <p class="hero-p">
      Más de <strong>35 años</strong> ayudando a las personas a encontrar su energía vital.<br
      />
      Trabajo con responsabilidad, respeto y <strong>total discreción</strong>.
    </p>

    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-wa"
      style="font-size:1.2rem;padding:22px 50px"
    >
      <WaIcon />
      Hablar con Isaías por WhatsApp
    </a>

    <p class="hero-avail">✨ Disponible ahora · Respuesta inmediata · 100% Confidencial</p>
  </div>

  <div class="scroll-hint">
    <span>Descubre más</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 120px 24px 90px;
    z-index: 1;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    animation: hero-zoom 14s ease-in-out infinite alternate;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        to bottom,
        rgba(4, 2, 14, 0.6) 0%,
        rgba(4, 2, 14, 0.15) 40%,
        rgba(4, 2, 14, 0.8) 100%
      ),
      radial-gradient(ellipse 80% 60% at 50% 50%, rgba(45, 27, 105, 0.5) 0%, transparent 70%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 960px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Cinzel', serif;
    font-size: 0.78rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #c9a84c;
    border: 1px solid rgba(201, 168, 76, 0.22);
    padding: 9px 22px;
    border-radius: 100px;
    margin-bottom: 36px;
    background: rgba(201, 168, 76, 0.07);
    animation: fade-up 0.8s ease both;
  }
  h1 {
    font-family: 'Cinzel Decorative', serif;
    line-height: 1.1;
    margin-bottom: 32px;
    animation: fade-up 0.8s 0.2s ease both;
  }
  .h1-name {
    display: block;
    font-size: clamp(2.4rem, 6vw, 5rem);
    font-weight: 900;
    color: #ede5d0;
    text-shadow:
      0 0 80px rgba(201, 168, 76, 0.3),
      0 2px 4px rgba(0, 0, 0, 0.5);
    letter-spacing: 0.06em;
  }
  .h1-gold {
    display: block;
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    font-weight: 700;
    font-style: normal;
    background: linear-gradient(135deg, #e8c870 0%, #c9a84c 45%, #e8a840 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    padding: 4px 0;
  }
  .h1-sub {
    display: block;
    font-size: clamp(1rem, 2.2vw, 1.6rem);
    font-weight: 400;
    color: #9e927a;
    letter-spacing: 0.14em;
    margin-top: 8px;
  }
  .hero-p {
    font-size: clamp(1.1rem, 1.7vw, 1.35rem);
    color: #9e927a;
    max-width: 660px;
    margin: 0 auto 44px;
    animation: fade-up 0.8s 0.4s ease both;
  }
  .hero-p strong {
    color: #c9a84c;
    font-weight: 500;
  }
  .hero-avail {
    display: block;
    margin-top: 18px;
    font-size: 0.9rem;
    color: #25d366;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.06em;
    animation: fade-up 0.8s 0.8s ease both;
    opacity: 0.9;
  }

  /* Sigils */
  .sigil {
    position: absolute;
    color: #7a6025;
    opacity: 0.55;
    font-size: 1.1rem;
    animation: sigil-f 6s ease-in-out infinite;
  }
  .s-tl {
    top: 64px;
    left: 48px;
    animation-delay: 0s;
  }
  .s-tr {
    top: 64px;
    right: 48px;
    animation-delay: 1.5s;
  }
  .s-bl {
    bottom: 90px;
    left: 48px;
    animation-delay: 3s;
  }
  .s-br {
    bottom: 90px;
    right: 48px;
    animation-delay: 4.5s;
  }
  @keyframes sigil-f {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.55;
    }
    50% {
      transform: translateY(-8px);
      opacity: 0.9;
    }
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 2;
    opacity: 0.4;
    animation: fade-up 1s 1.4s ease both;
  }
  .scroll-hint span {
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #c9a84c;
    font-family: 'Cinzel', serif;
  }
</style>

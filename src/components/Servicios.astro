---
import WaIcon from './WaIcon.astro'
const { link } = Astro.props

const topServices = [
  {
    img: '/velas5.jpeg',
    alt: 'Velas rojas rituales amarres de amor',
    badge: 'Más solicitado',
    title: 'Amarres de Amor',
    desc: 'Ritual espiritual para unir dos personas destinadas. Ideal para fortalecer relaciones, despertar sentimientos dormidos y recuperar la armonía sentimental. Para casos de ruptura, confusión o sentimientos mezclados.'
  },
  {
    img: '/velas6.jpeg',
    alt: 'Ritual espiritual retorno de pareja velas',
    badge: null,
    title: 'Retorno de Pareja',
    desc: 'Cuando el ser amado se alejó, se cerró o cambió. Se revisan bloqueos, distancia y terceras influencias. La guía es por etapas según el caso real para reconectar dos almas que pertenecen juntas.'
  }
]

const rowServices = [
  {
    img: '/velas7.jpeg',
    alt: 'Lectura de tarot orientación espiritual',
    title: 'Lectura Espiritual y Tarot',
    desc: 'Interpretación profunda para conocer situaciones del presente, pasado y futuro. Claridad para tus decisiones más importantes de amor y vida.'
  },
  {
    img: '/velas8.jpeg',
    alt: 'Limpieza espiritual despojo ritual',
    title: 'Limpiezas y Despojos',
    desc: 'Rituales para eliminar energías negativas, bloqueos y malas vibraciones. Libérate de todo lo que impide tu bienestar, prosperidad y paz interior.'
  },
  {
    img: '/velas1.jpeg',
    alt: 'Separación de amantes ritual protección',
    title: 'Separación de Amantes',
    desc: 'Para situaciones con terceras personas y enredos. Trabajo enfocado en limpiar influencias externas y recuperar el orden en tu relación.'
  },
  {
    img: '/velas2.jpeg',
    alt: 'Protección espiritual contra envidias energías',
    title: 'Protección Espiritual',
    desc: 'Rituales contra envidias, malas energías y ataques espirituales. Escudo energético permanente. También abre caminos en trabajo, dinero y negocios.'
  }
]
---

<section class="serv-sec" id="servicios">
  <div class="serv-inner">
    <div class="sec-header">
      <div class="rune-line"><span>⸻</span><span class="rune">☽ ✦ ☾</span><span>⸻</span></div>
      <h2>Mis Servicios Espirituales</h2>
      <p>
        Por medio de ritual y tradición ancestral, se orienta el proceso según tu caso.<br />La
        consulta define el enfoque, tiempos y etapas.
      </p>
    </div>

    <!-- Top 2 — imagen grande arriba -->
    <div class="top-grid">
      {
        topServices.map((s, i) => (
          <article class="card top-card reveal" style={`animation-delay:${i * 0.15}s`}>
            <div class="top-img-wrap">
              <img src={s.img} alt={s.alt} loading="lazy" />
              <div class="top-img-fade" />
              {s.badge && <span class="badge">{s.badge}</span>}
            </div>
            <div class="top-body">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <a href={link} target="_blank" rel="noopener noreferrer" class="btn-serv">
                <WaIcon />
                Consulta ahora
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <!-- 4 cards — imagen izquierda -->
    <div class="row-grid">
      {
        rowServices.map((s, i) => (
          <article class="card row-card reveal" style={`animation-delay:${i * 0.12}s`}>
            <div class="row-img">
              <img src={s.img} alt={s.alt} loading="lazy" />
            </div>
            <div class="row-body">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <a href={link} target="_blank" rel="noopener noreferrer" class="btn-serv">
                <WaIcon />
                Consulta ahora
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <p class="serv-disclaimer">
      ✦ Recomendación: evita "soluciones instantáneas". Un proceso serio se define por consulta
      y por etapas.
    </p>
  </div>
</section>

<style>
  .serv-sec {
    position: relative;
    z-index: 1;
    padding: 0 24px 100px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(80, 10, 10, 0.12) 50%,
      transparent 100%
    );
  }
  .serv-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Top cards */
  .top-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 28px;
    margin-bottom: 28px;
  }
  .top-card {
  }
  .top-img-wrap {
    position: relative;
    height: 300px;
    overflow: hidden;
  }
  .top-img-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 50%, rgba(4, 2, 14, 0.98) 100%);
  }
  .badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: #c9a84c;
    color: #04020e;
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
  }
  .top-body {
    padding: 28px 32px 36px;
  }
  .top-body h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #c9a84c;
    margin-bottom: 12px;
  }
  .top-body p {
    font-size: 1.05rem;
    color: #9e927a;
    line-height: 1.72;
    margin-bottom: 24px;
  }

  /* Row cards */
  .row-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
    gap: 20px;
  }
  .row-card {
    display: grid;
    grid-template-columns: 220px 1fr;
  }
  .row-img {
    min-height: 220px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .row-body {
    padding: 28px 30px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .row-body h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #c9a84c;
    margin-bottom: 10px;
  }
  .row-body p {
    font-size: 1rem;
    color: #9e927a;
    line-height: 1.65;
    margin-bottom: 20px;
    flex-grow: 1;
  }

  @media (max-width: 620px) {
    .row-card {
      grid-template-columns: 1fr;
    }
    .row-img {
      height: 220px;
    }
  }
  @media (max-width: 520px) {
    .row-grid {
      grid-template-columns: 1fr;
    }
  }

  .serv-disclaimer {
    text-align: center;
    margin-top: 40px;
    font-size: 0.9rem;
    color: #7a6025;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.05em;
    font-style: italic;
  }
</style>

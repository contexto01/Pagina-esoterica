---
import WaIcon from './WaIcon.astro'
const { link } = Astro.props

const pasos = [
  {
    num: 'I',
    title: 'Primer Contacto',
    desc: 'Escríbele a Isaías por WhatsApp. Recibirás respuesta inmediata con total discreción y confidencialidad.'
  },
  {
    num: 'II',
    title: 'Comparte tu Situación',
    desc: 'Explica tu situación sentimental, espiritual o personal. Cada caso se estudia espiritualmente antes de actuar.'
  },
  {
    num: 'III',
    title: 'Recibe Orientación',
    desc: 'Orientación personalizada y soluciones específicas para tu caso. La transformación comienza aquí.'
  }
]

const sideImg = '/velas4.jpeg'
---

<section class="pasos-sec" id="como-funciona">
  <div class="pasos-inner">
    <div class="pasos-img-col">
      <img src={sideImg} alt="Maestro espiritual ritual ancestral mística" loading="lazy" />
      <div class="pasos-img-fade"></div>
    </div>

    <div class="pasos-text-col reveal">
      <div class="rune-line" style="justify-content:flex-start;margin-bottom:20px">
        <span>⸻</span><span class="rune">☽ ✦ ☾</span><span>⸻</span>
      </div>
      <h2>¿Cómo funciona?</h2>
      <p class="pasos-intro">Un proceso simple, discreto y completamente confidencial.</p>

      <div class="steps">
        {
          pasos.map((p, i) => (
            <div class="step">
              <div class="step-num">{p.num}</div>
              <div class="step-body">
                <h3>{p.title}</h3>
                <p>{p.desc}</p>
              </div>
              {i < pasos.length - 1 && <div class="step-line" />}
            </div>
          ))
        }
      </div>

      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-wa"
        style="margin-top:44px;display:inline-flex"
      >
        <WaIcon />
        Iniciar consulta gratuita
      </a>
    </div>
  </div>
</section>

<style>
  .pasos-sec {
    position: relative;
    z-index: 1;
    overflow: hidden;
  }
  .pasos-inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    min-height: 680px;
  }
  @media (max-width: 860px) {
    .pasos-inner {
      grid-template-columns: 1fr;
    }
  }

  .pasos-img-col {
    position: relative;
    min-height: 520px;
    overflow: hidden;
  }
  .pasos-img-col img {
    height: 100%;
    object-fit: cover;
  }
  .pasos-img-fade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, transparent 55%, rgba(8, 5, 28, 1) 100%),
      linear-gradient(to bottom, rgba(4, 2, 14, 0.3) 0%, transparent 30%);
  }
  @media (max-width: 860px) {
    .pasos-img-fade {
      background: linear-gradient(to bottom, transparent 60%, rgba(8, 5, 28, 1) 100%);
    }
  }

  .pasos-text-col {
    background: rgba(8, 5, 28, 0.97);
    padding: 80px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (max-width: 860px) {
    .pasos-text-col {
      padding: 60px 28px;
    }
  }

  .pasos-text-col h2 {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
    color: #ede5d0;
    margin-bottom: 8px;
    line-height: 1.2;
  }
  .pasos-intro {
    font-size: 1.1rem;
    color: #9e927a;
    margin-bottom: 44px;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .step {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 0 22px;
    position: relative;
  }
  .step-num {
    width: 58px;
    height: 58px;
    border-radius: 50%;
    border: 1px solid #c9a84c;
    background: rgba(201, 168, 76, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cinzel Decorative', serif;
    font-size: 1rem;
    color: #c9a84c;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .step-body {
    padding: 8px 0 44px;
  }
  .step-body h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.15rem;
    color: #ede5d0;
    margin-bottom: 6px;
    font-weight: 600;
  }
  .step-body p {
    font-size: 1rem;
    color: #9e927a;
    line-height: 1.65;
  }
  .step-line {
    position: absolute;
    left: 28px;
    top: 58px;
    width: 1px;
    height: calc(100% - 58px);
    background: linear-gradient(to bottom, #7a6025, transparent);
    grid-column: 1;
  }
</style>
